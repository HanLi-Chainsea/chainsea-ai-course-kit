{
  "name": "AI 應用實戰課 學員包",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "bash setup.sh && ./.venv-course/bin/pip install -q -r m12-crew-starter/requirements.txt || true",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter", "astro-build.astro-vscode"],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv-course/bin/python",
        "python.terminal.activateEnvironment": false
      }
    }
  }
}
